#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// Hardware Pins
#define BUTTON_PIN 4 
#define LED_PIN 2
#define BUZZER_PIN 5

bool isTyping = false;

// --- YOUR SCRIPT LIBRARY ---
const char* scriptLibrary[] = {
  "> INITIATING GROUND-RADAR SWEEP...\n> SURFACE TARGET DETECTED.\n> CALCULATING FIRING SOLUTION.\n> WEAPONS FREE.",
  "> PID CONTROLLER: ONLINE.\n> CALIBRATING AZIMUTH MOTORS...\n> ERROR MARGIN < 0.02%.\n> AUTO-TRACKING ENGAGED.",
  "> TIME-DIFFERENCE-OF-ARRIVAL: ACTIVE.\n> ACOUSTIC SIGNATURE MATCHED.\n> TRIANGULATING ORIGIN POINT...\n> COORDINATES LOCKED.",
  "> SYSTEM BOOT SEQUENCE...\n> RUNNING HARDWARE DIAGNOSTICS...\n> ALL SYSTEMS NOMINAL.\n> AWAITING INPUT..."
};

const int numScripts = sizeof(scriptLibrary) / sizeof(scriptLibrary[0]);

void setup() {
  Serial.begin(115200);
  
  // Initialize Pins
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT); // Assumes Active Buzzer
  
  randomSeed(analogRead(34));

  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    for(;;);
  }

  display.setTextColor(SSD1306_WHITE, SSD1306_BLACK);
  
  // Turn on Idle LED
  digitalWrite(LED_PIN, HIGH);
  
  // Initial standby screen
  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("> STANDBY...");
  display.display();
}

void loop() {
  if (digitalRead(BUTTON_PIN) == LOW && !isTyping) {
    isTyping = true;
    
    // Turn off Idle LED while processing
    digitalWrite(LED_PIN, LOW);
    
    int scriptIndex = random(0, numScripts);
    
    display.clearDisplay();
    display.setCursor(0, 0);
    
    typeTextScramble(scriptLibrary[scriptIndex]);
    
    blinkCursor(4); 
    
    display.clearDisplay();
    display.setCursor(0, 0);
    display.print("> STANDBY...");
    display.display();
    
    // Turn Idle LED back on
    digitalWrite(LED_PIN, HIGH);
    
    isTyping = false;
    delay(500); // Debounce
  }
}

// The decryption scramble logic WITH OPTIMIZED BUZZER SYNC
void typeTextScramble(String text) {
  int scrambleIterations = 5; 
  
  for(int i = 0; i < text.length(); i++) {
    char targetChar = text.charAt(i);
    
    // Handle newlines silently (no screen redraw needed)
    if (targetChar == '\n') {
        display.print(targetChar);
        continue;
    }

    // Handle spaces 
    if (targetChar == ' ') {
      display.print(targetChar);
      display.display();
      delay(30); 
      continue;
    }
    
    int cursorX = display.getCursorX();
    int cursorY = display.getCursorY();
    
    // Scramble loop with rapid buzzer clicks
    for(int j = 0; j < scrambleIterations; j++) {
      // Crisp 2ms buzzer pulse isolated from the display render
      digitalWrite(BUZZER_PIN, HIGH);
      delay(2); 
      digitalWrite(BUZZER_PIN, LOW);
      
      display.setCursor(cursorX, cursorY);
      char randomChar = (char)random(33, 127); 
      display.print(randomChar);
      display.display();
      
      delay(12); // Pacing the visual scramble
    }
    
    // Lock in the final character
    display.setCursor(cursorX, cursorY);
    display.print(targetChar);
    display.display();
    delay(30); 
  }
}

void blinkCursor(int blinks) {
  for(int i = 0; i < blinks; i++) {
    int cursorX = display.getCursorX();
    int cursorY = display.getCursorY();
    
    display.setCursor(cursorX, cursorY);
    display.print("_");
    display.display();
    delay(400); 
    
    display.setCursor(cursorX, cursorY);
    display.print(" "); 
    display.display();
    delay(400); 
  }
}
